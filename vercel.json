{
  "framework": "vite",
  "buildCommand": "corepack pnpm --filter @workspace/moonsteel run build",
  "outputDirectory": "artifacts/moonsteel/dist/public",
  "installCommand": "corepack pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
